_ = a b c d e f g h i j k l m n o p q r s t u v w x y z

_ifthenelse t x y = if t then x else y

length = \xs =>
  match xs with
    nil | _ @ bar => zero
    cons _ xs => one + length xs  

($) : (a -> b) -> a -> b
($) f x = (f x)

flip = \f x y => f y x

main = forever loop
  where
    loop = do
      let x = -10 .. 256
      y <- do_something_monadic x
      ret $ y :: []
